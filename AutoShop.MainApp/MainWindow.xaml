<Window x:Class="AutoShop.MainApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutoShop.MainApp.Views"
        Title="AutoShop"
        Height="750"
        Width="1300">
    <Grid>
        <TabControl x:Name="MainTabs">
            <TabItem Header="Customers">
                <views:CustomerView />
            </TabItem>
            <TabItem Header="Vehicles">
                <views:VehicleView />
            </TabItem>
            <TabItem Header="Work Orders">
                <views:WorkOrderView />
            </TabItem>
            <TabItem x:Name="UsersTab" Header="Users">
                <views:UserManagementView />
            </TabItem>
            <TabItem x:Name="TechnicianDashboardTab" Header="Technician Dashboard">
                <views:TechnicianDashboardView />
            </TabItem>
            <TabItem x:Name="SettingsTab" Header="Shop Settings">
                <views:ShopSettingsView />
            </TabItem>
            <TabItem Header="Inventory">
                <views:PartView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>