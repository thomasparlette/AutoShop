<Window x:Class="AutoShop.MainApp.Views.InspectionChecklistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inspection Checklist"
        Height="800"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Vehicle Inspection Checklist" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Technician:" VerticalAlignment="Center" Width="80" />
                <TextBox Text="{Binding TechnicianName, UpdateSourceTrigger=PropertyChanged}" Width="280" />
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1"
          ItemsSource="{Binding Items}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Section" Binding="{Binding Section}" IsReadOnly="True" Width="150" />
                <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" IsReadOnly="True" Width="2*" />

                <DataGridTemplateColumn Header="Status" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.StatusOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Notes" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Overall Notes" />
            <TextBox Text="{Binding OverallNotes, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     Height="90"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Width="90" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
                <Button Content="Reload" Width="90" Margin="0,0,8,0" Command="{Binding ReloadCommand}" />
                <Button Content="Close" Width="90" Click="Close_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>