<UserControl x:Class="AutoShop.MainApp.Views.PurchaseOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <!-- Left side -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Purchase Orders" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="220"
                             Height="30"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Search" Width="80" Margin="0,0,8,0" Command="{Binding RefreshCommand}" />
                    <Button Content="New" Width="80" Margin="0,0,8,0" Command="{Binding NewCommand}" />
                    <Button Content="Draft From Low Stock" Width="140" Margin="0,0,8,0" Command="{Binding CreateDraftCommand}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="220"
                             Height="30"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SupplierFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Supplier Filter for Drafts"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <DataGrid ItemsSource="{Binding PurchaseOrders}"
                      SelectedItem="{Binding SelectedPurchaseOrder, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PO #"
                                        Binding="{Binding PoNumber}"
                                        Width="*" />
                    <DataGridTextColumn Header="Supplier"
                                        Binding="{Binding Supplier}"
                                        Width="2*" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="*" />
                    <DataGridTextColumn Header="Created"
                                        Binding="{Binding CreatedAt, StringFormat=g}"
                                        Width="*" />
                    <DataGridTextColumn Header="Ordered Total"
                                        Binding="{Binding OrderedTotal, StringFormat=C}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Right side -->
        <Border Grid.Column="2"
                Padding="16"
                BorderThickness="1"
                BorderBrush="Gray"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Purchase Order Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

                    <TextBlock Text="PO Number" />
                    <TextBox Text="{Binding CurrentPurchaseOrder.PoNumber, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Margin="0,0,0,8" />

                    <TextBlock Text="Supplier" />
                    <TextBox Text="{Binding CurrentPurchaseOrder.Supplier, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />

                    <TextBlock Text="Status" />
                    <TextBox Text="{Binding CurrentPurchaseOrder.Status}"
                             IsReadOnly="True"
                             Margin="0,0,0,8" />

                    <TextBlock Text="Notes" />
                    <TextBox Text="{Binding CurrentPurchaseOrder.Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="70"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8" />

                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Created At" />
                            <TextBox Text="{Binding CurrentPurchaseOrder.CreatedAt, StringFormat=g}"
                                     IsReadOnly="True" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Ordered At" />
                            <TextBox Text="{Binding CurrentPurchaseOrder.OrderedAt, StringFormat=g}"
                                     IsReadOnly="True" />
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Received At" />
                        <TextBox Text="{Binding CurrentPurchaseOrder.ReceivedAt, StringFormat=g}"
                                 IsReadOnly="True" />
                    </StackPanel>

                    <TextBlock Text="Line Items" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

                    <DataGrid ItemsSource="{Binding LineItems}"
                              SelectedItem="{Binding SelectedLineItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              CellEditEnding="LineItemsGrid_CellEditEnding"
                              Height="280"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Part #"
                                                Binding="{Binding PartNumber, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                Width="2*" />
                            <DataGridTextColumn Header="Ordered"
                                                Binding="{Binding QuantityOrdered, UpdateSourceTrigger=PropertyChanged}"
                                                Width="70" />
                            <DataGridTextColumn Header="Received"
                                                Binding="{Binding QuantityReceived, UpdateSourceTrigger=PropertyChanged}"
                                                Width="70" />
                            <DataGridTextColumn Header="Unit Cost"
                                                Binding="{Binding UnitCost, StringFormat=C, UpdateSourceTrigger=PropertyChanged}"
                                                Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{Binding OrderedQuantityTotal, StringFormat=Ordered Qty: {0}}" />
                        <TextBlock Text="{Binding ReceivedQuantityTotal, StringFormat=Received Qty: {0}}" />
                        <TextBlock Text="{Binding RemainingQuantityTotal, StringFormat=Remaining Qty: {0}}" />
                        <TextBlock Text="{Binding OrderedTotal, StringFormat=Ordered Total: {0:C}}" />
                        <TextBlock Text="{Binding ReceivedTotal, StringFormat=Received Total: {0:C}}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Add Part" Width="90" Margin="0,0,8,0" Command="{Binding AddPartCommand}" />
                        <Button Content="Remove Line" Width="100" Margin="0,0,8,0" Command="{Binding RemoveLineCommand}" />
                        <Button Content="Save" Width="90" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Mark Ordered" Width="100" Margin="0,0,8,0" Command="{Binding MarkOrderedCommand}" />
                        <Button Content="Receive" Width="90" Margin="0,0,8,0" Command="{Binding ReceiveCommand}" />
                        <Button Content="Cancel" Width="90" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
                        <Button Content="Clear" Width="90" Command="{Binding NewCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>