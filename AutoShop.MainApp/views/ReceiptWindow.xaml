<Window x:Class="AutoShop.MainApp.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DocumentTitle}"
        Height="850"
        Width="900"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <FlowDocumentScrollViewer Document="{Binding PreviewDocument}"
                              IsToolBarVisible="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto" />

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="Print" Width="90" Margin="0,0,8,0" Click="Print_Click" />
      <Button Content="Close" Width="90" Click="Close_Click" />
    </StackPanel>
  </Grid>
</Window>