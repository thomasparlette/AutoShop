<UserControl x:Class="AutoShop.MainApp.Views.TechnicianManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Technicians" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="220"
                             Height="30"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Search" Width="80" Margin="0,0,8,0" Command="{Binding RefreshCommand}" />
                    <Button Content="New" Width="80" Command="{Binding NewCommand}" />
                </StackPanel>

                <CheckBox Content="Show inactive"
                          IsChecked="{Binding ShowInactive}"
                          Margin="0,0,0,8" />
            </StackPanel>

            <DataGrid ItemsSource="{Binding Technicians}"
                      SelectedItem="{Binding SelectedTechnician, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*" />
                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*" />
                    <DataGridTextColumn Header="Rate" Binding="{Binding LaborRate, StringFormat=C}" Width="*" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding Active}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border Grid.Column="2" Padding="16" BorderThickness="1" BorderBrush="Gray" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Technician Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

                    <TextBlock Text="First Name" />
                    <TextBox Text="{Binding CurrentTechnician.FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Last Name" />
                    <TextBox Text="{Binding CurrentTechnician.LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Phone" />
                    <TextBox Text="{Binding CurrentTechnician.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Labor Rate" />
                    <TextBox Text="{Binding CurrentTechnician.LaborRate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <CheckBox Content="Active"
                              IsChecked="{Binding CurrentTechnician.Active}"
                              Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save" Width="90" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
                        <Button Content="Deactivate" Width="90" Margin="0,0,8,0" Command="{Binding DeactivateCommand}" />
                        <Button Content="Clear" Width="90" Command="{Binding NewCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>