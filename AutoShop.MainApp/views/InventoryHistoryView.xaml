<UserControl x:Class="AutoShop.MainApp.Views.InventoryHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1.6*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="Inventory History"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,12" />

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="250"
                     Height="30"
                     Margin="0,0,0,10" />

            <Button Content="Refresh"
                    Width="90"
                    Margin="0,0,0,10"
                    Command="{Binding RefreshCommand}" />

            <DataGrid ItemsSource="{Binding Parts}"
                      SelectedItem="{Binding SelectedPart, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Height="600">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Part #"
                                        Binding="{Binding PartNumber}"
                                        Width="*" />
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="2*" />
                    <DataGridTextColumn Header="Qty"
                                        Binding="{Binding QuantityOnHand}"
                                        Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Border Grid.Column="2"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <StackPanel>
                <TextBlock Text="Transactions"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,12" />

                <DataGrid ItemsSource="{Binding Transactions}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Height="620">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding TransactionDate, StringFormat=g}"
                                            Width="*" />
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding TransactionType}"
                                            Width="*" />
                        <DataGridTextColumn Header="Ref"
                                            Binding="{Binding ReferenceNumber}"
                                            Width="*" />
                        <DataGridTextColumn Header="Change"
                                            Binding="{Binding QuantityChange}"
                                            Width="*" />
                        <DataGridTextColumn Header="Before"
                                            Binding="{Binding QuantityBefore}"
                                            Width="*" />
                        <DataGridTextColumn Header="After"
                                            Binding="{Binding QuantityAfter}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>